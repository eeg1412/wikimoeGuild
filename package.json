{
  "name": "wikimoe-guild",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev:server": "pnpm --filter server dev",
    "dev:client": "pnpm --filter client dev",
    "dev": "concurrently -n server,client -c blue,green \"pnpm dev:server\" \"pnpm dev:client\"",
    "build:client": "pnpm --filter client build",
    "gen": "node scripts/generate.js",
    "admin-list": "pnpm --filter server admin-list",
    "admin-password-change": "pnpm --filter server admin-password-change",
    "reset-login-ip": "pnpm --filter server reset-login-ip",
    "reset-login-username": "pnpm --filter server reset-login-username"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
